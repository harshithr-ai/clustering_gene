# ============================================================
# Text2SQL — Environment Configuration
# ============================================================
# Fill in your Anthropic API key below.
# Get one at: https://console.anthropic.com/settings/keys
# ============================================================

ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Claude model to use for the agent. Recommended: claude-sonnet-4-5
ANTHROPIC_MODEL=claude-sonnet-4-5

# Path to the demo SQLite database (auto-created on first run)
DATABASE_PATH=demo.db

# Agent behavior
MAX_RETRIES=3
MAX_TOOL_CALLS=6
DEFAULT_ROW_LIMIT=1000
